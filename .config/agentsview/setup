#!/bin/sh

set -eu
umask 077

if [ "$#" -gt 1 ]; then
    echo "usage: $0 [--init-only]" >&2
    exit 64
fi

case ${1:-} in
    ''|--init-only) ;;
    *)
        echo "usage: $0 [--init-only]" >&2
        exit 64
        ;;
esac

config_home=${XDG_CONFIG_HOME:-"$HOME/.config"}
config_dir=$config_home/agentsview
template=$config_dir/service.local.example
local_config=$config_dir/service.local

if [ ! -r "$template" ]; then
    echo "agentsview: missing tracked template: $template" >&2
    exit 66
fi

mkdir -p "$config_dir"
chmod 700 "$config_dir"

if [ ! -e "$local_config" ]; then
    install -m 600 "$template" "$local_config"
    echo "agentsview: created $local_config"
else
    chmod 600 "$local_config"
    echo "agentsview: preserved existing $local_config"
fi

if [ "${1:-}" = --init-only ]; then
    echo "agentsview: customize $local_config, then rerun $0"
    exit 0
fi

# shellcheck source=/dev/null
. "$local_config"
agentsview_bin=${AGENTSVIEW_BIN:-"$HOME/.local/bin/agentsview"}
if [ ! -x "$agentsview_bin" ]; then
    agentsview_bin=$(command -v agentsview 2>/dev/null || true)
fi
if [ -z "$agentsview_bin" ] || [ ! -x "$agentsview_bin" ]; then
    echo "agentsview: install the agentsview binary before enabling its service" >&2
    exit 127
fi

case $(uname -s) in
    Linux)
        systemctl --user daemon-reload
        systemctl --user enable agentsview.service agentsview-binary.path
        systemctl --user restart agentsview.service
        systemctl --user start agentsview-binary.path

        if command -v loginctl >/dev/null 2>&1; then
            current_user=$(id -un)
            linger=$(loginctl show-user "$current_user" -p Linger --value 2>/dev/null || true)
            if [ "$linger" != yes ]; then
                echo "agentsview: enable boot-time user services with:"
                echo "  loginctl enable-linger \"$current_user\""
            fi
        fi
        ;;
    Darwin)
        domain=gui/$(id -u)
        label=$domain/io.agentsview.service
        plist=$HOME/Library/LaunchAgents/io.agentsview.service.plist

        if launchctl print "$label" >/dev/null 2>&1; then
            launchctl bootout "$label"
        fi

        attempts=0
        while launchctl print "$label" >/dev/null 2>&1; do
            attempts=$((attempts + 1))
            if [ "$attempts" -ge 50 ]; then
                echo "agentsview: timed out waiting for launchd to unload $label" >&2
                exit 75
            fi
            sleep 0.1
        done

        attempts=0
        until launchctl bootstrap "$domain" "$plist" 2>/dev/null; do
            attempts=$((attempts + 1))
            if [ "$attempts" -ge 20 ]; then
                echo "agentsview: launchd bootstrap failed for $plist" >&2
                launchctl bootstrap "$domain" "$plist"
                exit 1
            fi
            sleep 0.25
        done
        ;;
    *)
        echo "agentsview: unsupported service manager on $(uname -s)" >&2
        exit 69
        ;;
esac

echo "agentsview: service setup complete"
