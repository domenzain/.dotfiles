#!/bin/sh

set -eu
umask 077

usage() {
    echo "usage: $0 [--install-only|--enable|--disable|--restart|--status|--update]" >&2
    exit 64
}

if [ "$#" -gt 1 ]; then
    usage
fi

action=${1:---install-only}
case $action in
    --install-only|--enable|--disable|--restart|--status|--update) ;;
    *) usage ;;
esac

if [ "$(uname -s)" != Linux ]; then
    echo "codex: this setup currently supports systemd-based Linux hosts only" >&2
    exit 69
fi
if ! command -v systemctl >/dev/null 2>&1; then
    echo "codex: systemctl is required" >&2
    exit 69
fi

codex_home=${CODEX_HOME:-"$HOME/.codex"}
codex_bin=$codex_home/packages/standalone/current/bin/codex
service=codex-remote-control.service
path_unit=codex-binary.path

install_codex() {
    if ! command -v curl >/dev/null 2>&1; then
        echo "codex: curl is required to install the standalone CLI" >&2
        exit 69
    fi

    installer=$(mktemp "${TMPDIR:-/tmp}/codex-install.XXXXXX")
    curl -fsSL https://chatgpt.com/codex/install.sh -o "$installer"
    # Keep installation independent of shell startup files. Including the
    # visible command directory in PATH makes the official installer skip its
    # profile-editing step; hiding other package-manager bins also prevents a
    # stale npm Codex from being treated as the active install.
    PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin" \
        CODEX_NON_INTERACTIVE=1 \
        sh "$installer"
    rm -f "$installer"

    if [ ! -x "$codex_bin" ]; then
        echo "codex: installer did not create $codex_bin" >&2
        exit 70
    fi
}

require_codex() {
    if [ ! -x "$codex_bin" ]; then
        echo "codex: standalone executable not found: $codex_bin" >&2
        echo "codex: run $0 --install-only" >&2
        exit 127
    fi
}

require_login() {
    if ! "$codex_bin" login status >/dev/null 2>&1; then
        echo "codex: log in before enabling remote control:" >&2
        echo "  $codex_bin login" >&2
        exit 78
    fi
}

reload_units() {
    systemctl --user daemon-reload
}

wait_for_service() {
    attempts=0
    while ! "$codex_bin" app-server daemon version >/dev/null 2>&1; do
        attempts=$((attempts + 1))
        if ! systemctl --user is-active --quiet "$service" || [ "$attempts" -ge 80 ]; then
            echo "codex: app-server did not become ready" >&2
            systemctl --user status "$service" --no-pager >&2 || true
            exit 75
        fi
        sleep 0.25
    done
}

report_linger() {
    if command -v loginctl >/dev/null 2>&1; then
        current_user=$(id -un)
        linger=$(loginctl show-user "$current_user" -p Linger --value 2>/dev/null || true)
        if [ "$linger" != yes ]; then
            echo "codex: enable boot-time user services with:"
            echo "  loginctl enable-linger \"$current_user\""
        fi
    fi
}

case $action in
    --install-only|--update)
        # Avoid a duplicate restart if the path watcher sees the installer move
        # the standalone current symlink while setup is still running.
        path_was_active=0
        if systemctl --user is-active --quiet "$path_unit"; then
            path_was_active=1
            systemctl --user stop "$path_unit"
        fi
        service_was_active=0
        if systemctl --user is-active --quiet "$service"; then
            service_was_active=1
        fi

        install_codex
        reload_units

        if [ "$path_was_active" -eq 1 ] || systemctl --user is-enabled --quiet "$path_unit"; then
            systemctl --user start "$path_unit"
        fi
        if [ "$service_was_active" -eq 1 ]; then
            systemctl --user restart "$service"
            wait_for_service
        fi
        "$codex_bin" --version
        echo "codex: standalone install and optional service units are ready"
        ;;
    --enable)
        install_codex
        require_login
        reload_units
        systemctl --user enable "$service" "$path_unit"
        systemctl --user restart "$service"
        systemctl --user start "$path_unit"
        wait_for_service
        report_linger
        echo "codex: remote-control service enabled"
        ;;
    --disable)
        reload_units
        systemctl --user disable --now "$path_unit" "$service"
        echo "codex: remote-control service disabled"
        ;;
    --restart)
        require_codex
        require_login
        reload_units
        systemctl --user restart "$service"
        wait_for_service
        if systemctl --user is-enabled --quiet "$path_unit"; then
            systemctl --user start "$path_unit"
        fi
        echo "codex: remote-control service restarted"
        ;;
    --status)
        require_codex
        "$codex_bin" --version
        "$codex_bin" login status || true
        printf "service enabled: %s\n" "$(systemctl --user is-enabled "$service" 2>/dev/null || true)"
        printf "service active:  %s\n" "$(systemctl --user is-active "$service" 2>/dev/null || true)"
        printf "watcher enabled: %s\n" "$(systemctl --user is-enabled "$path_unit" 2>/dev/null || true)"
        printf "watcher active:  %s\n" "$(systemctl --user is-active "$path_unit" 2>/dev/null || true)"
        systemctl --user status "$service" "$path_unit" --no-pager || true
        ;;
esac
