#!/bin/sh

set -eu
umask 077

usage() {
    echo "usage: $0 [--install-only|--enable|--disable|--restart|--status|--update]" >&2
    exit 64
}

if [ "$#" -gt 1 ]; then
    usage
fi

action=${1:---install-only}
case $action in
    --install-only|--enable|--disable|--restart|--status|--update) ;;
    *) usage ;;
esac

if [ "$(uname -s)" != Linux ]; then
    echo "codex: this setup currently supports Linux hosts only" >&2
    exit 69
fi

config_home=${XDG_CONFIG_HOME:-"$HOME/.config"}
config_dir=$config_home/codex
unit_dir=$config_home/systemd/user
service=codex-remote-control.service
unit_template=$config_dir/systemd/$service
unit_link=$unit_dir/$service
codex_home=${CODEX_HOME:-"$HOME/.codex"}
codex_bin=$codex_home/packages/standalone/current/bin/codex

require_systemd() {
    if ! command -v systemctl >/dev/null 2>&1; then
        echo "codex: systemctl is required for service actions" >&2
        exit 69
    fi
}

install_codex() {
    if ! command -v curl >/dev/null 2>&1; then
        echo "codex: curl is required to install the standalone CLI" >&2
        exit 69
    fi

    installer=$(mktemp "${TMPDIR:-/tmp}/codex-install.XXXXXX")
    trap 'rm -f "$installer"' 0 1 2 15
    curl -fsSL https://chatgpt.com/codex/install.sh -o "$installer"
    # Keep installation independent of shell startup files. Including the
    # visible command directory makes the official installer skip profile
    # edits and hides stale package-manager installations from detection.
    PATH="$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin" \
        CODEX_NON_INTERACTIVE=1 \
        sh "$installer"
    rm -f "$installer"
    trap - 0 1 2 15

    if [ ! -x "$codex_bin" ]; then
        echo "codex: installer did not create $codex_bin" >&2
        exit 70
    fi
}

ensure_codex() {
    if [ ! -x "$codex_bin" ]; then
        install_codex
    fi
}

require_codex() {
    if [ ! -x "$codex_bin" ]; then
        echo "codex: standalone executable not found: $codex_bin" >&2
        echo "codex: run $0 --install-only" >&2
        exit 127
    fi
}

require_login() {
    if ! "$codex_bin" login status >/dev/null 2>&1; then
        echo "codex: device login is required before enabling remote control:" >&2
        echo "  $codex_bin login --device-auth" >&2
        exit 78
    fi
}

install_unit() {
    if [ ! -r "$unit_template" ]; then
        echo "codex: missing tracked unit template: $unit_template" >&2
        exit 66
    fi
    mkdir -p "$unit_dir"
    rm -f "$unit_link"
    ln -s "$unit_template" "$unit_link"
}

remove_unit() {
    rm -f "$unit_link"
}

remove_legacy_watcher() {
    systemctl --user disable --now codex-binary.path \
        codex-binary-restart.service >/dev/null 2>&1 || true
    rm -f "$unit_dir/codex-binary.path"
    rm -f "$unit_dir/codex-binary-restart.service"
}

wait_for_service() {
    attempts=0
    while ! "$codex_bin" app-server daemon version >/dev/null 2>&1; do
        attempts=$((attempts + 1))
        if ! systemctl --user is-active --quiet "$service" || [ "$attempts" -ge 80 ]; then
            echo "codex: app-server did not become ready" >&2
            systemctl --user status "$service" --no-pager >&2 || true
            exit 75
        fi
        sleep 0.25
    done
}

request_graceful_restart() {
    if systemctl --user is-active --quiet "$service"; then
        # Codex handles SIGHUP by draining every running assistant turn before
        # exiting. Restart=always then launches the installed binary.
        systemctl --user kill --kill-who=main --signal=SIGHUP "$service"
        echo "codex: graceful restart requested; active turns will finish first"
    else
        systemctl --user start "$service"
        wait_for_service
    fi
}

restart_if_version_changed() {
    if ! systemctl --user is-active --quiet "$service"; then
        return
    fi

    version_json=$("$codex_bin" app-server daemon version 2>/dev/null || true)
    managed_version=$(printf '%s\n' "$version_json" |
        sed -n 's/.*"managedCodexVersion":"\([^"]*\)".*/\1/p')
    running_version=$(printf '%s\n' "$version_json" |
        sed -n 's/.*"appServerVersion":"\([^"]*\)".*/\1/p')

    if [ -n "$managed_version" ] && [ -n "$running_version" ] &&
        [ "$managed_version" != "$running_version" ]
    then
        request_graceful_restart
    fi
}

report_linger() {
    if command -v loginctl >/dev/null 2>&1; then
        current_user=$(id -un)
        linger=$(loginctl show-user "$current_user" -p Linger --value 2>/dev/null || true)
        if [ "$linger" != yes ]; then
            echo "codex: enable boot-time user services with:"
            echo "  loginctl enable-linger \"$current_user\""
        fi
    fi
}

case $action in
    --install-only)
        ensure_codex
        "$codex_bin" --version
        ;;
    --update)
        require_systemd
        install_codex
        restart_if_version_changed
        "$codex_bin" --version
        ;;
    --enable)
        require_systemd
        ensure_codex
        require_login
        install_unit
        remove_legacy_watcher
        systemctl --user daemon-reload
        systemctl --user enable "$service"
        request_graceful_restart
        report_linger
        echo "codex: remote-control service enabled"
        ;;
    --disable)
        require_systemd
        systemctl --user disable --now "$service" >/dev/null 2>&1 || true
        remove_legacy_watcher
        remove_unit
        systemctl --user daemon-reload
        echo "codex: remote-control service disabled and uninstalled"
        ;;
    --restart)
        require_systemd
        require_codex
        require_login
        install_unit
        systemctl --user daemon-reload
        request_graceful_restart
        ;;
    --status)
        require_systemd
        require_codex
        "$codex_bin" --version
        "$codex_bin" login status || true
        printf "unit installed:  %s\n" "$([ -L "$unit_link" ] && echo yes || echo no)"
        printf "service enabled: %s\n" "$(systemctl --user is-enabled "$service" 2>/dev/null || true)"
        printf "service active:  %s\n" "$(systemctl --user is-active "$service" 2>/dev/null || true)"
        systemctl --user status "$service" --no-pager || true
        ;;
esac
