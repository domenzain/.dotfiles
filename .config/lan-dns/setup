#!/bin/sh

set -eu
umask 077

usage() {
    echo "usage: $0 [--init-only]" >&2
}

if [ "$#" -gt 1 ]; then
    usage
    exit 64
fi

case ${1:-} in
    ''|--init-only) ;;
    *)
        usage
        exit 64
        ;;
esac

config_home=${XDG_CONFIG_HOME:-"$HOME/.config"}
config_dir=$config_home/lan-dns
local_template=$config_dir/node.local.example
local_config=$config_dir/node.local
hosts_template=$config_dir/hosts.local.example
hosts_file=$config_dir/hosts.local
base_config=$config_dir/dnsmasq-lan.conf
unit_file=$config_dir/dnsmasq-lan.service
firewall_script=$config_dir/lan-dns-firewall
firewall_unit_file=$config_dir/lan-dns-firewall.service
firewall_timer_file=$config_dir/lan-dns-firewall.timer
sync_template=$config_dir/sync.local.example
sync_config=$config_dir/sync.local
export_script=$config_dir/lan-dns-export
sync_script=$config_dir/lan-dns-sync
sync_unit_file=$config_dir/lan-dns-sync.service
sync_timer_file=$config_dir/lan-dns-sync.timer
tailscale_ssh_unit_file=$config_dir/lan-dns-tailscale-ssh.service
lock_dir=/run/lock/lan-dns
lock_file=$lock_dir/sync.lock

for required_file in "$local_template" "$hosts_template" "$base_config" "$unit_file" \
    "$firewall_script" "$firewall_unit_file" "$firewall_timer_file" \
    "$sync_template" "$export_script" "$sync_script" "$sync_unit_file" \
    "$sync_timer_file" "$tailscale_ssh_unit_file"; do
    if [ ! -r "$required_file" ]; then
        echo "lan-dns: missing tracked file: $required_file" >&2
        exit 66
    fi
done

mkdir -p "$config_dir"
chmod 700 "$config_dir"
if [ ! -e "$local_config" ]; then
    install -m 600 "$local_template" "$local_config"
    echo "lan-dns: created $local_config"
else
    chmod 600 "$local_config"
    echo "lan-dns: preserved existing $local_config"
fi
if [ ! -e "$hosts_file" ]; then
    install -m 600 "$hosts_template" "$hosts_file"
    echo "lan-dns: created $hosts_file"
else
    chmod 600 "$hosts_file"
    echo "lan-dns: preserved existing $hosts_file"
fi
if [ -e "$sync_config" ]; then
    chmod 600 "$sync_config"
    echo "lan-dns: replication requested by $sync_config"
fi

if [ "${1:-}" = --init-only ]; then
    echo "lan-dns: customize $local_config and $hosts_file, then rerun $0"
    echo "lan-dns: optionally copy $sync_template to $sync_config to enable replication"
    exit 0
fi

if [ "$(uname -s)" != Linux ] || ! command -v systemctl >/dev/null 2>&1 || ! command -v apt-get >/dev/null 2>&1; then
    echo "lan-dns: this setup requires Linux with systemd and apt" >&2
    exit 69
fi

run_as_root() {
    if [ "$(id -u)" -eq 0 ]; then
        "$@"
    elif command -v sudo >/dev/null 2>&1; then
        sudo "$@"
    else
        echo "lan-dns: sudo is required when not running as root" >&2
        return 77
    fi
}

# shellcheck source=/dev/null
. "$local_config"
upstream=${LAN_DNS_UPSTREAM:-}
lan_interface=${LAN_DNS_LAN_INTERFACE:-}
if [ "${LAN_DNS_TAILSCALE_INTERFACE+x}" = x ]; then
    tailscale_interface=$LAN_DNS_TAILSCALE_INTERFACE
else
    tailscale_interface=tailscale0
fi
restrict_ssh_ipv6=${LAN_DNS_RESTRICT_SSH_IPV6:-0}

case $restrict_ssh_ipv6 in
    0|1) ;;
    *)
        echo "lan-dns: LAN_DNS_RESTRICT_SSH_IPV6 must be 0 or 1 in $local_config" >&2
        exit 65
        ;;
esac

sync_enabled=0
if [ -e "$sync_config" ]; then
    sync_enabled=1
fi

if ! printf '%s\n' "$upstream" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
    echo "lan-dns: set LAN_DNS_UPSTREAM to an IPv4 address in $local_config" >&2
    exit 65
fi

route_output=$(ip -4 route get "$upstream" 2>/dev/null) || {
    echo "lan-dns: cannot route to upstream $upstream" >&2
    exit 69
}
if [ -z "$lan_interface" ]; then
    lan_interface=$(printf '%s\n' "$route_output" | sed -n 's/.* dev \([^ ]*\).*/\1/p' | sed -n '1p')
fi

case $lan_interface in
    ''|lo|tailscale0)
        echo "lan-dns: unsafe LAN interface result: ${lan_interface:-empty}" >&2
        exit 65
        ;;
    *[!A-Za-z0-9_.@-]*)
        echo "lan-dns: invalid LAN interface name: $lan_interface" >&2
        exit 65
        ;;
esac
if ! ip link show dev "$lan_interface" >/dev/null 2>&1; then
    echo "lan-dns: LAN interface does not exist: $lan_interface" >&2
    exit 69
fi

if [ -n "$tailscale_interface" ]; then
    case $tailscale_interface in
        lo|"$lan_interface"|*[!A-Za-z0-9_.@-]*)
            echo "lan-dns: invalid Tailscale interface: $tailscale_interface" >&2
            exit 65
            ;;
    esac
fi

if run_as_root systemctl is-active --quiet dnsmasq.service; then
    echo "lan-dns: refusing to compete with active dnsmasq.service" >&2
    exit 73
fi

need_base_packages=0
need_sync_packages=0
if ! command -v dnsmasq >/dev/null 2>&1 || ! command -v dig >/dev/null 2>&1 || \
    ! command -v nft >/dev/null 2>&1 || ! command -v flock >/dev/null 2>&1; then
    need_base_packages=1
fi
if [ "$sync_enabled" -eq 1 ] && \
    { ! command -v python3 >/dev/null 2>&1 || ! command -v ssh >/dev/null 2>&1; }; then
    need_sync_packages=1
fi
if [ "$need_base_packages" -eq 1 ] || [ "$need_sync_packages" -eq 1 ]; then
    run_as_root apt-get update
fi
if [ "$need_base_packages" -eq 1 ]; then
    run_as_root apt-get install -y dnsmasq-base dnsutils nftables util-linux
fi
if [ "$need_sync_packages" -eq 1 ]; then
    run_as_root apt-get install -y openssh-client python3
fi

sync_mode=none
if [ "$sync_enabled" -eq 1 ]; then
    run_as_root python3 "$sync_script" --config "$sync_config" --validate-config
    sync_mode=$(run_as_root python3 "$sync_script" --config "$sync_config" --print-mode)
    run_as_root python3 "$sync_script" --config "$sync_config" --validate-hosts "$hosts_file"
fi
if [ "$sync_mode" = source ] && ! command -v tailscale >/dev/null 2>&1; then
    echo 'lan-dns: source mode requires the Tailscale CLI' >&2
    exit 69
fi

# The root timer and this user-invoked setup share the same advisory lock. Keep
# its directory root-owned and non-writable; grant only this setup user's
# primary group permission to open the otherwise data-free lock file.
lock_group=$(id -g)
run_as_root install -d -o root -g "$lock_group" -m 0750 "$lock_dir"
run_as_root touch "$lock_file"
run_as_root chown root:"$lock_group" "$lock_file"
run_as_root chmod 0660 "$lock_file"
exec 9>>"$lock_file"
flock -x 9

expected_ip=$(awk '
    $1 !~ /^#/ {
        if (NF >= 2) {
            print $1
            exit
        }
    }
' "$hosts_file")
verify_name=$(awk '$1 !~ /^#/ && NF >= 2 { print $2; exit }' "$hosts_file")
if [ -z "$expected_ip" ] || [ -z "$verify_name" ]; then
    echo "lan-dns: add at least one private record to $hosts_file" >&2
    exit 65
fi

tmp_dir=$(mktemp -d)
cleanup() {
    rm -rf "$tmp_dir"
}
trap cleanup EXIT HUP INT TERM
candidate_config=$tmp_dir/dnsmasq-lan.conf
candidate_firewall_config=$tmp_dir/lan-dns-firewall.conf

{
    echo '# Generated by ~/.config/lan-dns/setup; edit node.local or tracked sources.'
    echo 'bind-dynamic'
    echo "interface=$lan_interface"
    if [ -n "$tailscale_interface" ]; then
        echo "interface=$tailscale_interface"
    fi
    echo 'except-interface=lo'
    echo "server=$upstream"
    cat "$base_config"
} > "$candidate_config"

{
    echo '# Generated by ~/.config/lan-dns/setup; rerun setup after changing node.local.'
    printf "LAN_DNS_LAN_INTERFACE='%s'\n" "$lan_interface"
    printf 'LAN_DNS_RESTRICT_SSH_IPV6=%s\n' "$restrict_ssh_ipv6"
} > "$candidate_firewall_config"

/usr/sbin/dnsmasq --test --conf-file="$candidate_config"
sh -n "$firewall_script"
if command -v systemd-analyze >/dev/null 2>&1; then
    systemd-analyze verify "$unit_file" "$firewall_unit_file" "$firewall_timer_file"
    if [ "$sync_mode" = source ]; then
        systemd-analyze verify "$tailscale_ssh_unit_file"
    fi
fi

changed=0
install_if_changed() {
    source_file=$1
    target_file=$2
    target_mode=$3
    if run_as_root test -e "$target_file" && run_as_root cmp -s "$source_file" "$target_file"; then
        return 0
    fi
    run_as_root install -m "$target_mode" "$source_file" "$target_file"
    changed=1
}

install_if_changed "$hosts_file" /etc/dnsmasq-lan.hosts 0644
install_if_changed "$candidate_config" /etc/dnsmasq-lan.conf 0644
install_if_changed "$unit_file" /etc/systemd/system/dnsmasq-lan.service 0644
run_as_root install -d -m 0755 /usr/local/libexec
install_if_changed "$firewall_script" /usr/local/libexec/lan-dns-firewall 0755
install_if_changed "$candidate_firewall_config" /etc/lan-dns-firewall.conf 0600
install_if_changed "$firewall_unit_file" /etc/systemd/system/lan-dns-firewall.service 0644
install_if_changed "$firewall_timer_file" /etc/systemd/system/lan-dns-firewall.timer 0644
if [ "$sync_enabled" -eq 1 ]; then
    install_if_changed "$export_script" /usr/local/libexec/lan-dns-export 0755
    if [ "$sync_mode" = replica ]; then
        install_if_changed "$sync_script" /usr/local/libexec/lan-dns-sync 0755
        install_if_changed "$sync_config" /etc/lan-dns-sync.conf 0600
        run_as_root chmod 0600 /etc/lan-dns-sync.conf
        install_if_changed "$sync_unit_file" /etc/systemd/system/lan-dns-sync.service 0644
        install_if_changed "$sync_timer_file" /etc/systemd/system/lan-dns-sync.timer 0644
        if command -v systemd-analyze >/dev/null 2>&1; then
            # The unit references the installed absolute executable path, so
            # verify it only after that root-owned helper exists.
            systemd-analyze verify "$sync_unit_file" "$sync_timer_file"
        fi
    elif [ "$sync_mode" = source ]; then
        install_if_changed "$tailscale_ssh_unit_file" /etc/systemd/system/lan-dns-tailscale-ssh.service 0644
    fi
fi

if [ "$changed" -eq 1 ]; then
    run_as_root systemctl daemon-reload
fi
run_as_root systemctl enable --now lan-dns-firewall.timer
if ! run_as_root systemctl start lan-dns-firewall.service; then
    run_as_root systemctl stop dnsmasq-lan.service || true
    echo 'lan-dns: IPv6 firewall failed; stopped DNS rather than leave port 53 exposed' >&2
    exit 70
fi
run_as_root systemctl enable dnsmasq-lan.service
if ! run_as_root systemctl is-active --quiet dnsmasq-lan.service; then
    run_as_root systemctl start dnsmasq-lan.service
elif [ "$changed" -eq 1 ]; then
    run_as_root systemctl restart dnsmasq-lan.service
fi
run_as_root systemctl is-active --quiet dnsmasq-lan.service

verify_address() {
    verify_ip=$1
    for transport in udp tcp; do
        if [ "$transport" = tcp ]; then
            tcp_option=+tcp
        else
            tcp_option=
        fi
        attempt=1
        while :; do
            answer=
            if answer=$(dig $tcp_option +short +time=2 +tries=1 @"$verify_ip" "$verify_name" A) && \
                printf '%s\n' "$answer" | grep -Fx "$expected_ip" >/dev/null 2>&1; then
                break
            fi
            if [ "$attempt" -ge 3 ]; then
                echo "lan-dns: $transport verification failed through $verify_ip" >&2
                exit 70
            fi
            attempt=$((attempt + 1))
            sleep 1
        done
    done
    echo "lan-dns: verified UDP and TCP through $verify_ip"
}

lan_addresses=$(ip -o -4 address show dev "$lan_interface" scope global | awk '{ sub(/\/.*/, "", $4); print $4 }')
if [ -z "$lan_addresses" ]; then
    echo "lan-dns: no global IPv4 address on $lan_interface" >&2
    exit 69
fi
for verify_ip in $lan_addresses; do
    verify_address "$verify_ip"
done

if [ -n "$tailscale_interface" ] && ip link show dev "$tailscale_interface" >/dev/null 2>&1; then
    tailscale_addresses=$(ip -o address show dev "$tailscale_interface" scope global | awk '{ sub(/\/.*/, "", $4); print $4 }')
    for verify_ip in $tailscale_addresses; do
        verify_address "$verify_ip"
    done
else
    echo "lan-dns: Tailscale interface absent or disabled; LAN-only service is healthy"
fi

# Do not invoke the pull service while setup still owns their shared lock.
flock -u 9

if [ "$sync_mode" = replica ]; then
    run_as_root systemctl disable --now lan-dns-tailscale-ssh.service >/dev/null 2>&1 || true
    run_as_root systemctl enable --now lan-dns-sync.timer
    if ! run_as_root systemctl start lan-dns-sync.service; then
        echo 'lan-dns: initial replication failed; the timer will retry and last-good records remain active' >&2
    fi
elif [ "$sync_mode" = source ]; then
    # Switching a configured node from replica to source must stop an old pull
    # timer. A fresh source has no such unit, hence the deliberately quiet no-op.
    run_as_root systemctl disable --now lan-dns-sync.timer >/dev/null 2>&1 || true
    run_as_root systemctl enable lan-dns-tailscale-ssh.service
    run_as_root systemctl --no-block start lan-dns-tailscale-ssh.service
    echo 'lan-dns: source exporter installed; Tailscale SSH will enable after tailnet authentication'
    echo 'lan-dns: authorize the replica forced command and Tailscale SSH policy separately'
else
    run_as_root systemctl disable --now lan-dns-tailscale-ssh.service >/dev/null 2>&1 || true
fi

echo "lan-dns: setup complete on $lan_interface"
